{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koushi",
  "version": "0.1.0",
  "identifier": "chat.koushi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Koushi",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/koushi-desktop/media_downloads/**"]
      },
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost koushi-thumbnail: http://koushi-thumbnail.localhost https://koushi-thumbnail.localhost; connect-src ipc: http://ipc.localhost; font-src 'self'; frame-ancestors 'none'; object-src 'none'",
      "devCsp": "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost koushi-thumbnail: http://koushi-thumbnail.localhost https://koushi-thumbnail.localhost; connect-src ipc: http://ipc.localhost http://127.0.0.1:5173 ws://127.0.0.1:5173; font-src 'self' data:; frame-ancestors 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "publisher": "Koushi contributors",
    "homepage": "https://github.com/matrix-org/matrix-rust-sdk",
    "icon": [
      "icons/icon.svg",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "copyright": "Copyright 2026 Koushi contributors",
    "license": "MIT OR Apache-2.0",
    "category": "SocialNetworking",
    "shortDescription": "Koushi — a Matrix desktop client.",
    "longDescription": "Koushi is a Matrix desktop client used to validate Matrix Rust SDK desktop integration, encrypted local stores, search, and Element-like desktop workflows.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "c3a2679e-7752-532b-9880-068d6f969880"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "signCommand": null
    }
  }
}
