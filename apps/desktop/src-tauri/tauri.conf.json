{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "matrix-desktop",
  "version": "0.1.0",
  "identifier": "org.shinaoka.matrix-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "matrix-desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "targets": "all"
  }
}
