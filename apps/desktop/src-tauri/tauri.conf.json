{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "matrix-desktop",
  "version": "0.1.0",
  "identifier": "org.example.matrix-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "matrix-desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src ipc: http://ipc.localhost; font-src 'self'; frame-ancestors 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "publisher": "matrix-desktop contributors",
    "homepage": "https://github.com/matrix-org/matrix-rust-sdk",
    "icon": [],
    "copyright": "Copyright 2026 matrix-desktop contributors",
    "license": "MIT",
    "category": "SocialNetworking",
    "shortDescription": "A Tauri Matrix desktop client.",
    "longDescription": "matrix-desktop is a Tauri Matrix desktop client used to validate Matrix Rust SDK desktop integration, encrypted local stores, search, and Element-like desktop workflows.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "c3a2679e-7752-532b-9880-068d6f969880"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "signCommand": null
    }
  }
}
