{
  "name": "matrix-desktop-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "qa:mac-gui": "node ../../scripts/desktop-mac-gui-smoke.mjs --run",
    "qa:linux-gui": "node ../../scripts/desktop-linux-gui-qa.mjs --run",
    "qa:headless-local": "node ../../scripts/desktop-headless-local-qa.mjs --run",
    "qa:headless-core": "node ../../scripts/desktop-headless-local-qa.mjs --run --core",
    "qa:manual": "node ../../scripts/desktop-manual-qa.mjs --markdown",
    "qa:real-account": "cargo run -p matrix-desktop-sdk --features smoke --bin password-login-smoke -- --real-account-qa",
    "qa:real-homeserver": "node ../../scripts/desktop-real-homeserver-qa.mjs --run",
    "release:preflight": "node ../../scripts/desktop-release-preflight.mjs --check-config",
    "release:preflight:strict": "node ../../scripts/desktop-release-preflight.mjs --strict-signing",
    "test": "vitest run",
    "test:ipc-contract": "cargo test --manifest-path src-tauri/Cargo.toml core_event_wire_format_matches_checked_in_contract_artifact",
    "test:ui-headless": "vitest run --reporter=verbose src/domain/timelineStore.test.ts && playwright test",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "qa:secret-scan": "node ../../scripts/desktop-secret-scan.mjs",
    "qa:wasm-check": "cargo check --target wasm32-unknown-unknown -p matrix-desktop-state -p matrix-desktop-search",
    "qa:release-gates": "node ../../scripts/desktop-release-gate-check.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@types/node": "^25.9.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "webdriverio": "^9.28.0"
  }
}
